{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": ["Edit", "Write", "MultiEdit"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "volicord guard session-start --host-output claude-code",
            "timeout": 30,
            "statusMessage": "Checking Volicord session"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|mcp__.*__(write|edit|create|update|delete|remove|move|patch).*",
        "hooks": [
          {
            "type": "command",
            "command": "volicord guard pre-tool --host-output claude-code",
            "timeout": 30,
            "statusMessage": "Checking Volicord write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|mcp__.*__(write|edit|create|update|delete|remove|move|patch).*",
        "hooks": [
          {
            "type": "command",
            "command": "volicord guard post-tool --host-output claude-code",
            "timeout": 30,
            "statusMessage": "Recording Volicord write"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "volicord guard prompt-capture --host-output claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "volicord guard stop --host-output claude-code",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
