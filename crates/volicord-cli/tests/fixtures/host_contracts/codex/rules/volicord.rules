prefix_rule(
    pattern = [".codex", "hooks"],
    decision = "prompt",
    justification = "Volicord hook wrappers may observe local lifecycle state.",
    match = [
        ".codex/hooks/volicord-session-start.sh",
        ".codex/hooks/volicord-pre-tool.sh",
    ],
    not_match = [
        "volicord status",
    ],
)
